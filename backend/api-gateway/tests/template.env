MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=adminpassword
MYSQL_DATABASE=tdn
MYSQL_USER=user
MYSQL_PASSWORD=userpassword
MYSQL_ROOT_PASSWORD=rootpassword

# URL'ы сервисов
