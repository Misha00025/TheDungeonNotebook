# Пути к ключам RSA
PRIVATE_KEY_PATH=/certs/private.pem
PUBLIC_KEY_PATH=/certs/public.pem
REDIS_CONNECTION_STRING=redis:6379
ASPNETCORE_URLS=http://0.0.0.0:8080;http://0.0.0.0:8081
OIDC_ISSUER_URL=http://auth-service:8080
OIDC_ISSUER=http://auth-service:8080
MONGO_SCHEMAS_DATABASE=tdn-schemas
